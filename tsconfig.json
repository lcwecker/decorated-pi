{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "types": ["node"],
    "outDir": "dist",
    "rootDir": ".",
    "noEmit": true
  },
  "include": ["extensions/**/*.ts", "test/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}