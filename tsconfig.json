{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "types": ["node"],
    "outDir": "dist",
    "rootDir": ".",
    "noEmit": true
  },
  "include": [
    "index.ts",
    "settings.ts",
    "tools/**/*.ts",
    "hooks/**/*.ts",
    "commands/**/*.ts",
    "providers/**/*.ts",
    "ui/**/*.ts",
    "utils/**/*.ts",
    "test/**/*.ts"
  ],
  "exclude": ["node_modules", "dist"]
}